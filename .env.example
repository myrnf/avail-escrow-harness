# Optional: WalletConnect Cloud projectId. Without one, injected wallets
# (MetaMask, Rabby, Coinbase Wallet extension) still work fine on testnet.
# Get one at https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: override the default Base Sepolia public RPC if you have one.
# Default is https://sepolia.base.org (rate-limited but free).
VITE_BASE_SEPOLIA_RPC=
