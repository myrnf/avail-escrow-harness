# Test-solver backend env. Copy to .env for local dev; set the same names on
# your hosting provider (Render env vars, fly.toml secrets, etc.) for prod.

# KalqiX auth (mint via SIWE → PUT /api-keys; secret is shown once)
KALQIX_API_KEY=
KALQIX_API_SECRET=
KALQIX_BASE_URL=https://api.kalqix.com/v1

# The EOA that holds Base mainnet inventory AND is registered with KalqiX
# as the trading account. Hex, no 0x prefix.
SOLVER_PRIVATE_KEY=

# Base mainnet RPC. Public endpoint is fine for low traffic.
BASE_RPC_URL=https://mainnet.base.org

# CORS allowlist — comma-separated origins. Include the Vercel preview pattern
# + production URL. No wildcards.
ALLOWED_ORIGINS=http://localhost:5174,https://avail-escrow-harness.vercel.app

# Per-swap caps to limit blast radius of any bug. Base units.
MAX_SWAP_USDC=50000000     # 50 USDC (6 decimals)
MAX_SWAP_CBBTC=60000        # 0.0006 cbBTC (8 decimals) ≈ $50 at ~$80k/cbBTC

# Token addresses (Base mainnet). Override only if testing against forks.
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
CBBTC_ADDRESS=0xcbB7C0000aB88B473b1f5aFd9ef808440eed33Bf

# KalqiX market ticker (slash form). Currently the only supported pair.
KALQIX_MARKET=cbBTC/USDC

# Bearer token for /admin/swaps. Make it a long random string.
ADMIN_BEARER_TOKEN=

# Server bind. Render maps $PORT automatically; local dev uses 3000.
BIND_ADDR=0.0.0.0:3000

# Optional log level. Defaults to info.
RUST_LOG=test_solver=debug,tower_http=info
